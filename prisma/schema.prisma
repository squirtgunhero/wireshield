generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ORGANIZATIONS ───

model Organization {
  id        String   @id @default(uuid())
  name      String
  type      OrgType
  altaId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

enum OrgType {
  TITLE_COMPANY
  BROKERAGE
  LENDER
  LAW_FIRM
}

// ─── USERS ───

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  phone            String?
  fullName         String
  role             UserRole @default(AGENT)
  organizationId   String?
  avatarUrl        String?

  identityVerified        Boolean   @default(false)
  identityVerifiedAt      DateTime?
  identityProvider        String?
  identityConfidenceScore Decimal?  @db.Decimal(5, 2)
  deviceFingerprint       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  createdTransactions Transaction[]     @relation("TransactionCreator")
  transactionParties  TransactionParty[]
  submittedWires      WireInstruction[]  @relation("WireSubmitter")
  riskEventsResolved  RiskEvent[]        @relation("RiskResolver")
  emailAnalyses       EmailAnalysis[]
  alerts              Alert[]
  auditLogs           AuditLog[]
  notifications       Notification[]
}

enum UserRole {
  BUYER
  SELLER
  AGENT
  TITLE_OFFICER
  ESCROW_OFFICER
  LENDER
  ATTORNEY
  ADMIN
}

// ─── TRANSACTIONS ───

model Transaction {
  id              String          @id @default(uuid())
  colonyDealId    String?
  transactionType TransactionType @default(PURCHASE)
  status          TxStatus        @default(ACTIVE)
  currentPhase    Phase           @default(LISTING)

  propertyAddress String
  propertyCity    String?
  propertyState   String?
  propertyZip     String?

  purchasePrice       Decimal? @db.Decimal(12, 2)
  expectedCloseDate   DateTime?

  riskScore Int?      @default(0) @db.SmallInt
  riskLevel RiskLevel @default(PENDING)

  insuranceTier           InsuranceTier?
  insuranceCoverageAmount Decimal?       @db.Decimal(12, 2)

  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User? @relation("TransactionCreator", fields: [createdById], references: [id])

  parties          TransactionParty[]
  wireInstructions WireInstruction[]
  riskEvents       RiskEvent[]
  emailAnalyses    EmailAnalysis[]
  events           Event[]
  documents        Document[]
  alerts           Alert[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  fincenReports    FinCENReport[]
}

enum TransactionType {
  PURCHASE
  REFINANCE
  SALE
}

enum TxStatus {
  ACTIVE
  PENDING_VERIFICATION
  FUNDED
  CLOSED
  CANCELLED
  ON_HOLD
}

enum Phase {
  LISTING
  OFFER
  EARNEST_MONEY
  DUE_DILIGENCE
  UNDERWRITING
  CLOSING
  POST_CLOSING
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
  PENDING
}

enum InsuranceTier {
  STANDARD
  PREMIUM
  ENTERPRISE
}

// ─── TRANSACTION PARTIES ───

model TransactionParty {
  id            String      @id @default(uuid())
  transactionId String
  userId        String?
  role          PartyRole
  invitedAt     DateTime    @default(now())
  verifiedAt    DateTime?
  status        PartyStatus @default(INVITED)

  name    String
  email   String
  phone   String?
  company String?

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id])

  eventsFrom       Event[]           @relation("EventFrom")
  eventsTo         Event[]           @relation("EventTo")
  wiresSubmitted   WireInstruction[] @relation("WireFromParty")
  wiresReceived    WireInstruction[] @relation("WireToParty")

  @@unique([transactionId, userId, role])
}

enum PartyRole {
  BUYER
  SELLER
  LISTING_AGENT
  BUYER_AGENT
  TITLE_OFFICER
  ESCROW_OFFICER
  ATTORNEY
  LENDER
  OTHER
}

enum PartyStatus {
  INVITED
  ONBOARDING
  VERIFIED
  REMOVED
}

// ─── WIRE INSTRUCTIONS ───

model WireInstruction {
  id            String   @id @default(uuid())
  transactionId String
  submittedById String?
  direction     WireDirection

  bankName                String
  routingNumber           String
  accountNumberEncrypted  String
  accountHolderName       String
  bankAddress             String?
  swiftCode               String?
  amount                  Decimal?  @db.Decimal(12, 2)

  plaidVerified       Boolean  @default(false)
  plaidVerificationId String?
  accountAgeDays      Int?

  status               WireInstructionStatus @default(PENDING)
  verificationChecksum String?
  expiresAt            DateTime?

  deliveredAt  DateTime?
  confirmedAt  DateTime?
  flaggedAt    DateTime?
  flaggedBy    String?
  flagReason   String?

  fromPartyId String?
  toPartyId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction       @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  submittedBy User?             @relation("WireSubmitter", fields: [submittedById], references: [id])
  fromParty   TransactionParty? @relation("WireFromParty", fields: [fromPartyId], references: [id])
  toParty     TransactionParty? @relation("WireToParty", fields: [toPartyId], references: [id])
}

enum WireDirection {
  INCOMING
  OUTGOING
}

enum WireInstructionStatus {
  PENDING
  VERIFIED
  DELIVERED
  CONFIRMED
  FLAGGED
  EXPIRED
  CANCELLED
}

// ─── EVENTS (activity feed) ───

model Event {
  id            String    @id @default(uuid())
  transactionId String
  phase         Phase
  type          EventType
  severity      Severity  @default(INFO)

  fromPartyId String?
  toPartyId   String?
  fromLabel   String?

  subject    String
  detail     String  @db.Text
  rawContent String? @db.Text

  flagged    Boolean @default(false)
  threatType String?
  flags      Json?
  aiSummary  String? @db.Text
  aiAnalysis Json?

  sourceType String?
  sourceId   String?
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())

  transaction Transaction       @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  fromParty   TransactionParty? @relation("EventFrom", fields: [fromPartyId], references: [id])
  toParty     TransactionParty? @relation("EventTo", fields: [toPartyId], references: [id])
  alerts      Alert[]
}

enum EventType {
  COMMUNICATION
  WIRE
  DOCUMENT
  VERIFICATION
  PHASE_CHANGE
  IDENTITY_CHECK
  BANK_VALIDATION
  EMAIL_ANALYSIS
  BEHAVIORAL
  SYSTEM
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
  SAFE
}

// ─── RISK EVENTS ───

model RiskEvent {
  id            String   @id @default(uuid())
  transactionId String
  eventType     String
  severity      Severity
  title         String
  description   String?  @db.Text
  metadata      Json?
  resolved      Boolean  @default(false)
  resolvedById  String?
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  resolvedBy  User?       @relation("RiskResolver", fields: [resolvedById], references: [id])
}

// ─── EMAIL ANALYSES ───

model EmailAnalysis {
  id                  String   @id @default(uuid())
  transactionId       String?
  submittedById       String?
  rawEmailEncrypted   String   @db.Text
  senderAddress       String?
  senderDomain        String?
  domainAgeDays       Int?
  domainMatch         Boolean?
  replyToMismatch     Boolean?
  urgencyScore        Decimal? @db.Decimal(5, 2)
  toneShiftDetected   Boolean?
  spoofingIndicators  Json?
  riskScore           Int?     @db.SmallInt
  aiAnalysis          String?  @db.Text
  verdict             EmailVerdict?
  createdAt           DateTime @default(now())

  transaction Transaction? @relation(fields: [transactionId], references: [id])
  submittedBy User?        @relation(fields: [submittedById], references: [id])
}

enum EmailVerdict {
  VERIFIED
  SUSPICIOUS
  FRAUDULENT
}

// ─── DOCUMENTS ───

model Document {
  id            String    @id @default(uuid())
  transactionId String
  name          String
  phase         Phase
  status        DocStatus @default(PENDING)

  fileUrl  String?
  fileType String?
  fileSize Int?

  signedAt    DateTime?
  verifiedAt  DateTime?
  verifiedBy  String?
  signatories String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

enum DocStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  FLAGGED
  REJECTED
}

// ─── ALERTS ───

model Alert {
  id            String      @id @default(uuid())
  transactionId String
  eventId       String?
  severity      Severity
  title         String
  description   String      @db.Text
  status        AlertStatus @default(ACTIVE)

  assignedToId String?

  resolvedAt DateTime?
  resolvedBy String?
  resolution String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  event       Event?      @relation(fields: [eventId], references: [id])
  assignedTo  User?       @relation(fields: [assignedToId], references: [id])
}

enum AlertStatus {
  ACTIVE
  INVESTIGATING
  RESOLVED
  FALSE_POSITIVE
  ESCALATED
}

// ─── AUDIT LOG (append-only) ───

model AuditLog {
  id            String   @id @default(uuid())
  transactionId String?
  userId        String?
  action        String
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  deviceFingerprint Json?
  geoLocation   Json?
  createdAt     DateTime @default(now())

  transaction Transaction? @relation(fields: [transactionId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
}

// ─── NOTIFICATIONS ───

model Notification {
  id            String   @id @default(uuid())
  userId        String
  transactionId String?
  channel       NotificationChannel
  type          String
  title         String
  body          String   @db.Text
  sentAt        DateTime?
  readAt        DateTime?
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
  IN_APP
}

// ─── FINCEN REPORTS ───

model FinCENReport {
  id            String          @id @default(uuid())
  transactionId String
  reportType    String
  filingData    Json
  filedAt       DateTime?
  filingReference String?
  status        FinCENStatus    @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])
}

enum FinCENStatus {
  DRAFT
  READY
  FILED
  ACCEPTED
  REJECTED
}
